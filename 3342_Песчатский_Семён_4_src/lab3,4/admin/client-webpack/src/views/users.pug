doctype html
html(lang="ru")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Пользователи - Админ панель
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet")
    link(rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👥</text></svg>")

  body
    //- Навигация
    nav.navbar.navbar-expand-lg.navbar-dark.bg-primary
      .container
        a.navbar-brand(href="/webpack/users")
          i.bi.bi-people-fill.me-2
          | Социальная сеть - Админ
        .navbar-nav.ms-auto
          a.nav-link.active(href="/webpack/users")
            i.bi.bi-people.me-1
            | Пользователи
          a.nav-link(href="/webpack/friends")
            i.bi.bi-person-heart.me-1
            | Друзья
          a.nav-link(href="/webpack/news")
            i.bi.bi-newspaper.me-1
            | Новости

    //- Основной контент
    .container.mt-4
      //- Заголовок
      .row.mb-4
        .col-12
          .d-flex.justify-content-between.align-items-center
            div
              h1.h3.mb-1
                i.bi.bi-people.text-primary.me-2
                | Управление пользователями
              p.text-muted
                | Всего пользователей: 
                span#users-count.fw-bold 0
            .d-flex.gap-2
              button#refresh-users.btn.btn-primary
                i.bi.bi-arrow-clockwise.me-1
                | Обновить
              button.btn.btn-outline-secondary(onclick="resetFilters()")
                i.bi.bi-x-circle.me-1
                | Сбросить фильтры

      //- Фильтры
      .row.mb-4
        .col-12
          .card
            .card-body
              .row.g-3
                .col-md-6
                  label.form-label Поиск по имени или email
                  input#search-input.form-control(type="text" placeholder="Введите имя или email...")
                .col-md-3
                  label.form-label Статус
                  select#status-filter.form-select
                    option(value="") Все статусы
                    option(value="active") Активный
                    option(value="pending") Не подтверждённый
                    option(value="blocked") Заблокированный
                .col-md-3
                  label.form-label Роль
                  select#role-filter.form-select
                    option(value="") Все роли
                    option(value="admin") Администратор
                    option(value="user") Пользователь

      //- КОНТЕЙНЕР ДЛЯ ПОЛЬЗОВАТЕЛЕЙ
      .row
        .col-12
          #users-container
            .text-center.py-5

    //- Модальное окно редактирования
    .modal.fade#editUserModal(tabindex="-1")
      .modal-dialog
        .modal-content
          .modal-header
            h5.modal-title Редактирование пользователя
            button.btn-close(type="button" data-bs-dismiss="modal")
          .modal-body
            form#edit-user-form
              input#edit-user-id(type="hidden")
              .mb-3
                label.form-label ФИО
                input#edit-fullName.form-control(type="text" required)
              .mb-3
                label.form-label Email
                input#edit-email.form-control(type="email" required)
              .mb-3
                label.form-label Дата рождения
                input#edit-birthDate.form-control(type="date" required)
              .mb-3
                label.form-label Роль
                select#edit-role.form-select(required)
                  option(value="user") Пользователь
                  option(value="admin") Администратор
              .mb-3
                label.form-label Статус
                select#edit-status.form-select(required)
                  option(value="active") Активный
                  option(value="pending") Не подтверждённый
                  option(value="blocked") Заблокированный
          .modal-footer
            button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Отмена
            button#save-user-changes.btn.btn-primary(type="button")
              i.bi.bi-check-lg.me-1
              | Сохранить

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js")