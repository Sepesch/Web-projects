html(lang="ru")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Новости - Админ панель
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet")
    link(rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👥</text></svg>")

  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-primary
      .container
        a.navbar-brand(href="/webpack/users")
          i.bi.bi-people-fill.me-2
          | Социальная сеть - Админ
        .navbar-nav.ms-auto
          a.nav-link(href="/webpack/users")
            i.bi.bi-people.me-1
            | Пользователи
          a.nav-link(href="/webpack/friends")
            i.bi.bi-person-heart.me-1
            | Друзья
          a.nav-link.active(href="/webpack/news")
            i.bi.bi-newspaper.me-1
            | Новости

    .container.mt-4
      .row.mb-4
        .col-12
          h1.h3.mb-1
            i.bi.bi-newspaper.text-primary.me-2
            | Лента новостей
          p.text-muted Просмотр и модерация новостей от друзей пользователей

      .row.mb-4
        .col-12
          .card
            .card-body
              .row.align-items-end
                .col-md-6
                  label.form-label.fw-bold Выберите пользователя для просмотра ленты его друзей:
                  select#user-select.form-select
                    option(value="") -- Выберите пользователя --
                .col-md-3
                  label.form-label Статус новостей
                  select#news-filter.form-select
                    option(value="all") Все новости
                    option(value="active") Только активные
                    option(value="blocked") Заблокированные
                .col-md-3
                  button#refresh-news.btn.btn-primary.w-100
                    i.bi.bi-arrow-clockwise.me-1
                    | Обновить ленту

      .row.mb-4
        .col-12
          .row
            .col-md-4
              .card.bg-primary.text-white
                .card-body.text-center
                  i.bi.bi-chat-dots.display-6
                  h4.mt-2#total-news 0
                  p.mb-0 Всего новостей
            .col-md-4
              .card.bg-success.text-white
                .card-body.text-center
                  i.bi.bi-check-circle.display-6
                  h4.mt-2#active-news 0
                  p.mb-0 Активных новостей
            .col-md-4
              .card.bg-danger.text-white
                .card-body.text-center
                  i.bi.bi-slash-circle.display-6
                  h4.mt-2#blocked-news 0
                  p.mb-0 Заблокированных

      .row
        .col-12.col-lg-8.mx-auto
          #news-container
            .text-center.py-5
              i.bi.bi-newspaper.display-1.text-muted
              p.mt-3.text-muted Выберите пользователя для просмотра новостей его друзей

    .modal.fade#blockNewsModal(tabindex="-1")
      .modal-dialog
        .modal-content
          .modal-header
            h5.modal-title#block-modal-title Блокировка новости
            button.btn-close(type="button" data-bs-dismiss="modal")
          .modal-body
            input#block-news-id(type="hidden")
            .mb-3
              label.form-label Причина блокировки
              textarea#block-reason.form-control(rows="3" placeholder="Укажите причину блокировки...")
            .alert.alert-warning
              i.bi.bi-exclamation-triangle.me-2
              | Заблокированная новость будет скрыта из ленты всех пользователей.
          .modal-footer
            button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Отмена
            button#confirm-block.btn.btn-danger(type="button")
              i.bi.bi-slash-circle.me-1
              | Заблокировать

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js")